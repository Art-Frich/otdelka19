---
import { getCollection } from 'astro:content';
import Base from '@/layouts/Base.astro';
import Hero from '@/components/Hero.astro';
import About from '@/components/About.astro';
import Services from '@/components/Services.astro';
import PortfolioGrid from '@/components/PortfolioGrid.astro';
import Contacts from '@/components/Contacts.astro';
import Button from '@/components/Button.astro';

const projects = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => b.data.order - a.data.order)
  .slice(0, 6);
---

<Base path="/">
  <Hero />
  <About />
  <Services />

  <section
    id="raboty"
    class="bg-[linear-gradient(180deg,transparent,color-mix(in_srgb,var(--color-accent)_4%,transparent))] py-[72px]"
  >
    <div class="container-x">
      <div class="mb-11 max-w-[46em]">
        <div class="text-[13px] font-semibold uppercase tracking-[0.14em] text-accent">Портфолио</div>
        <h2 class="mt-2.5 text-[clamp(26px,3.4vw,38px)] font-extrabold">
          Работы в Абакане и Черногорске
        </h2>
        <p class="mt-3 text-[17px] text-muted">
          Каждый объект — отдельный кейс с фото и составом работ. Нажмите, чтобы посмотреть.
        </p>
      </div>

      {
        projects.length > 0 ? (
          <PortfolioGrid projects={projects} />
        ) : (
          <p class="text-muted">Кейсы скоро появятся.</p>
        )
      }

      <div class="mt-10">
        <Button href="/portfolio/" variant="secondary">Все работы →</Button>
      </div>
    </div>
  </section>

  <Contacts />
</Base>
