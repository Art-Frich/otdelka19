---
import { getCollection } from 'astro:content';
import Base from '@/layouts/Base.astro';
import PortfolioGrid from '@/components/PortfolioGrid.astro';
import SectionHead from '@/components/SectionHead.astro';
import { breadcrumbSchema } from '@/lib/jsonld';

const projects = (await getCollection('projects', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.order - a.data.order
);

const base = Astro.site?.href ?? 'https://otdelka19.ru/';
const crumbs = breadcrumbSchema(base, [
  { name: 'Главная', item: '/' },
  { name: 'Портфолио', item: '/portfolio/' },
]);
---

<Base
  title="Портфолио работ"
  description="Портфолио ремонта и отделки квартир в Абакане и Черногорске: фото объектов, состав и этапы работ."
  path="/portfolio/"
  jsonld={[crumbs]}
>
  <section class="py-[72px]">
    <div class="container-x">
      <SectionHead
        as="h1"
        class="mb-11 max-w-[46em]"
        eyebrow="Портфолио"
        title="Мои работы"
        desc="Объекты в Абакане и Черногорске — фото и состав работ по каждому кейсу."
      />

      {
        projects.length > 0 ? (
          <PortfolioGrid projects={projects} />
        ) : (
          <p class="text-muted">Кейсы скоро появятся.</p>
        )
      }
    </div>
  </section>
</Base>
