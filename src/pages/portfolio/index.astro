---
import { getCollection } from 'astro:content';
import Base from '@/layouts/Base.astro';
import PortfolioGrid from '@/components/PortfolioGrid.astro';
import { breadcrumbSchema } from '@/lib/jsonld';

const projects = (await getCollection('projects', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.order - a.data.order
);

const base = Astro.site?.href ?? 'https://otdelka19.ru/';
const crumbs = breadcrumbSchema(base, [
  { name: 'Главная', item: '/' },
  { name: 'Портфолио', item: '/portfolio/' },
]);
---

<Base
  title="Портфолио работ"
  description="Портфолио ремонта и отделки квартир в Абакане и Черногорске: реальные объекты до/после, метраж, сроки и этапы работ."
  path="/portfolio/"
  jsonld={[crumbs]}
>
  <section class="py-[72px]">
    <div class="mx-auto max-w-[1120px] px-6">
      <div class="mb-11 max-w-[46em]">
        <div class="text-[13px] font-semibold uppercase tracking-[0.14em] text-accent">Портфолио</div>
        <h1 class="mt-2.5 text-[clamp(30px,4vw,48px)] font-extrabold">Мои работы</h1>
        <p class="mt-3 text-[17px] text-muted">
          Объекты в Абакане и Черногорске. Каждый кейс — с фото до/после, метражом и сроками.
        </p>
      </div>

      {
        projects.length > 0 ? (
          <PortfolioGrid projects={projects} />
        ) : (
          <p class="text-muted">Кейсы скоро появятся.</p>
        )
      }
    </div>
  </section>
</Base>
