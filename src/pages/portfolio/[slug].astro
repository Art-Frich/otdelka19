---
import { getCollection, render } from 'astro:content';
import Base from '@/layouts/Base.astro';
import BeforeAfter from '@/components/BeforeAfter.astro';
import { breadcrumbSchema, projectSchema } from '@/lib/jsonld';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map((project) => ({ params: { slug: project.id }, props: { project } }));
}

const { project } = Astro.props;
const d = project.data;
const { Content } = await render(project);
const base = Astro.site?.href ?? 'https://otdelka19.ru/';

const titleLine = d.area ? `${d.title}, ${d.area} м²` : d.title;
const metaItems = [d.type, d.district, d.duration].filter(Boolean);
const isCompare = !!(d.beforeImage && d.afterImage);
const cover = d.cover || d.afterImage || d.gallery?.[0]?.src;

const galleryImages: { src: string; alt: string }[] = [];
if (cover) galleryImages.push({ src: cover, alt: d.title });
for (const g of d.gallery ?? []) {
  if (g.src !== cover) galleryImages.push({ src: g.src, alt: g.alt || d.title });
}

const galleryPayload = (start: number) =>
  JSON.stringify({ mode: 'gallery', images: galleryImages, title: titleLine, start });
const comparePayload = JSON.stringify({
  mode: 'compare',
  before: d.beforeImage,
  after: d.afterImage,
  title: titleLine,
});

// миниатюры под героем
const thumbs = isCompare
  ? galleryImages.map((g, i) => ({ ...g, start: i }))
  : galleryImages.slice(1).map((g, i) => ({ ...g, start: i + 1 }));

const crumbs = breadcrumbSchema(base, [
  { name: 'Главная', item: '/' },
  { name: 'Портфолио', item: '/portfolio/' },
  { name: titleLine, item: `/portfolio/${project.id}/` },
]);
const proj = projectSchema(base, project.id, d);
---

<Base
  title={d.seo?.title ?? `${titleLine} — ${d.type}`}
  description={d.seo?.description ?? d.summary}
  path={`/portfolio/${project.id}/`}
  image={cover}
  type="article"
  jsonld={[crumbs, proj]}
>
  <article class="py-[56px]">
    <div class="mx-auto max-w-[960px] px-6">
      <nav class="text-[13px] text-muted">
        <a href="/portfolio/" class="hover:text-fg">← Все работы</a>
      </nav>
      <h1 class="mt-4 text-[clamp(28px,4vw,44px)] font-extrabold">{titleLine}</h1>
      <p class="mt-3 max-w-[40em] text-[17px] text-muted">{d.summary}</p>

      <div class="mt-5 flex flex-wrap gap-2">
        {
          metaItems.map((m) => (
            <span class="rounded-full border border-border bg-surface px-3 py-1.5 text-[13px] text-muted">
              {m}
            </span>
          ))
        }
      </div>

      {/* герой */}
      <div class="relative mt-8 overflow-hidden rounded-2xl border border-border">
        {
          isCompare ? (
            <>
              <div class="aspect-[4/3]">
                <BeforeAfter before={d.beforeImage!} after={d.afterImage!} alt={d.title} />
              </div>
              <button
                type="button"
                data-lb={comparePayload}
                aria-label="Открыть на весь экран"
                class="absolute bottom-3 right-3 z-30 inline-flex items-center gap-1.5 rounded-full bg-fg/75 px-3 py-1.5 text-xs font-semibold text-bg backdrop-blur transition hover:bg-fg"
              >
                До / После <span class="text-[13px]">⤢</span>
              </button>
            </>
          ) : cover ? (
            <button type="button" data-lb={galleryPayload(0)} class="block w-full" aria-label="Открыть фото">
              <img src={cover} alt={d.title} class="aspect-[4/3] w-full object-cover" />
            </button>
          ) : null
        }
      </div>

      {/* миниатюры */}
      {
        thumbs.length > 0 && (
          <div class="mt-3 grid grid-cols-3 gap-3 sm:grid-cols-4">
            {thumbs.map((t) => (
              <button
                type="button"
                data-lb={galleryPayload(t.start)}
                class="aspect-square overflow-hidden rounded-xl border border-border"
                aria-label="Открыть фото"
              >
                <img
                  src={t.src}
                  alt={t.alt}
                  loading="lazy"
                  class="h-full w-full object-cover transition duration-300 hover:scale-105"
                />
              </button>
            ))}
          </div>
        )
      }

      <div class="case-body mt-10">
        <Content />
      </div>

      <div class="mt-12 rounded-2xl border border-border bg-surface p-8 text-center">
        <h2 class="text-2xl font-extrabold">Хотите так же?</h2>
        <p class="mx-auto mt-2 max-w-[34em] text-muted">
          Позвоните или напишите — обсудим ваш объект, сроки и приеду на замер.
        </p>
        <a
          href="/#kontakty"
          class="mt-5 inline-flex h-12 items-center rounded-full bg-accent px-6 font-semibold text-accent-fg"
          >Связаться</a
        >
      </div>
    </div>
  </article>
</Base>
