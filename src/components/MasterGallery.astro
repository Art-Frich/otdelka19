---
// Мини-галерея фото мастера: переключение стрелками/точками (ваниль-JS).
// Фото берутся из CMS (Настройки → Фото мастера), а не зашиты в код.
// Один источник для мобильной и десктопной раскладки «О мастере».
import site from '@/data/site.json';
import { withBase } from '@/lib/url';

interface Props {
  class?: string;
}
const { class: className } = Astro.props;

const photos = (site.masterPhotos ?? []).map((p) => ({ src: withBase(p.src), alt: p.alt }));
const multiple = photos.length > 1;
---

{
  photos.length > 0 && (
    <div
      class:list={[
        'master-gallery relative aspect-[3/4] overflow-hidden rounded-2xl border border-border shadow-[0_30px_60px_-30px_rgba(0,0,0,0.3)]',
        className,
      ]}
      data-master-gallery
    >
      {photos.map((p, i) => (
        <img
          src={p.src}
          alt={p.alt}
          loading="lazy"
          data-slide={i}
          class:list={[
            'absolute inset-0 h-full w-full object-cover transition-opacity duration-500',
            i === 0 ? 'opacity-100' : 'opacity-0',
          ]}
        />
      ))}

      {multiple && (
        <Fragment>
          <button
            type="button"
            class="mg-prev absolute left-2 top-1/2 grid h-9 w-9 -translate-y-1/2 cursor-pointer place-items-center rounded-full bg-black/35 text-white backdrop-blur-sm transition hover:bg-black/60"
            aria-label="Предыдущее фото"
          >
            <svg
              class="h-5 w-5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="m15 18-6-6 6-6" />
            </svg>
          </button>

          <button
            type="button"
            class="mg-next absolute right-2 top-1/2 grid h-9 w-9 -translate-y-1/2 cursor-pointer place-items-center rounded-full bg-black/35 text-white backdrop-blur-sm transition hover:bg-black/60"
            aria-label="Следующее фото"
          >
            <svg
              class="h-5 w-5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="m9 18 6-6-6-6" />
            </svg>
          </button>

          <div class="absolute bottom-3 left-1/2 flex -translate-x-1/2 gap-1.5">
            {photos.map((_, i) => (
              <span
                data-dot={i}
                class:list={['mg-dot h-1.5 w-1.5 rounded-full transition', i === 0 ? 'bg-white' : 'bg-white/50']}
              />
            ))}
          </div>
        </Fragment>
      )}
    </div>
  )
}

<script>
  document.querySelectorAll('[data-master-gallery]').forEach((g) => {
    const slides = Array.from(g.querySelectorAll('[data-slide]'));
    const dots = Array.from(g.querySelectorAll('[data-dot]'));
    if (slides.length < 2) return;
    let i = 0;
    const show = (n: number) => {
      i = (n + slides.length) % slides.length;
      slides.forEach((s, k) => {
        s.classList.toggle('opacity-100', k === i);
        s.classList.toggle('opacity-0', k !== i);
      });
      dots.forEach((d, k) => {
        d.classList.toggle('bg-white', k === i);
        d.classList.toggle('bg-white/50', k !== i);
      });
    };
    g.querySelector('.mg-prev')?.addEventListener('click', () => show(i - 1));
    g.querySelector('.mg-next')?.addEventListener('click', () => show(i + 1));
    dots.forEach((d, k) => d.addEventListener('click', () => show(k)));
  });
</script>
