---
// Интерактивный слайдер «до/после» (разметка). Логика drag — в глобальном
// скрипте Lightbox.astro (wireSlider по [data-ba]).
interface Props {
  before: string;
  after: string;
  alt?: string;
  class?: string;
}
const { before, after, alt = '', class: className = '' } = Astro.props;
---

<div class:list={['ba', className]} data-ba>
  <img class="ba-after" src={after} alt={alt ? `После ремонта — ${alt}` : 'После ремонта'} draggable="false" />
  <img class="ba-before" src={before} alt={alt ? `До ремонта — ${alt}` : 'До ремонта'} draggable="false" />
  <span class="ba-badge is-before">ДО</span>
  <span class="ba-badge is-after">ПОСЛЕ</span>
  <div class="ba-handle"><span class="ba-line"></span><span class="ba-grip">⇆</span></div>
</div>
