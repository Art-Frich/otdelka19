---
import site from '@/data/site.json';
import SectionHead from '@/components/SectionHead.astro';
---

<section id="uslugi" class="py-[72px]">
  <div class="container-x">
    <SectionHead
      class="mb-11 max-w-[46em]"
      eyebrow="Что делаю"
      title="Полный цикл отделочных работ"
      desc={site.servicesIntro}
    />
    <div class="grid grid-cols-1 gap-[18px] sm:grid-cols-2 lg:grid-cols-4">
      {
        site.services.map((s) => (
          <div class="rounded-2xl border border-border bg-surface p-6 transition hover:-translate-y-1 hover:shadow-[0_20px_40px_-26px_rgba(0,0,0,0.25)]">
            <div class="mb-4 grid h-11 w-11 place-items-center rounded-xl bg-accent-soft text-accent">
              {s.icon}
            </div>
            <h3 class="text-lg font-bold">{s.title}</h3>
            <p class="mt-2 text-sm text-muted">{s.text}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
