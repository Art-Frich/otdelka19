---
// Фото мастера: портрет + врезка «на объекте» (picture-in-picture).
// Один источник для мобильной и десктопной раскладки «О мастере».
import site from '@/data/site.json';
import { withBase } from '@/lib/url';

interface Props {
  class?: string;
}
const { class: className } = Astro.props;

const portrait = withBase(site.masterPhoto || '/img/master/portrait.webp');
const atWork = withBase('/img/master/at-work.webp');
const alt = `Мастер-отделочник ${site.masterName}, Абакан`;
---

<div class:list={['relative', className]}>
  <img
    src={portrait}
    alt={alt}
    loading="lazy"
    class="w-full rounded-2xl border border-border object-cover shadow-[0_30px_60px_-30px_rgba(0,0,0,0.3)]"
  />
  <img
    src={atWork}
    alt="Мастер на объекте — отделочные работы"
    loading="lazy"
    class="absolute bottom-3 right-3 w-[42%] rounded-xl border-[4px] border-bg object-cover shadow-[0_18px_36px_-16px_rgba(0,0,0,0.5)]"
  />
</div>
