---
// Глобальный лайтбокс + логика всех слайдеров «до/после» на странице.
// Триггер: любой элемент с атрибутом data-lb='{"mode":"compare"|"gallery", ...}'.
---

<div class="lb" id="lb" role="dialog" aria-modal="true" aria-hidden="true">
  <button class="lb__close" id="lb-close" aria-label="Закрыть">✕</button>
  <div class="lb__inner">
    <div class="lb__title" id="lb-title"></div>
    <div class="lb__stage" id="lb-stage"></div>
    <div id="lb-controls"></div>
  </div>
</div>

<script>
  type Img = { src: string; alt?: string };
  type LbData =
    | { mode: 'compare'; before: string; after: string; title?: string }
    | { mode: 'gallery'; images: Img[]; title?: string; start?: number };

  // --- слайдер «до/после» ---
  function wireSlider(ba: HTMLElement) {
    const before = ba.querySelector('.ba-before');
    const handle = ba.querySelector('.ba-handle');
    if (!(before instanceof HTMLElement) || !(handle instanceof HTMLElement)) return;
    let drag = false;
    const set = (p: number) => {
      const v = Math.max(0, Math.min(100, p));
      before.style.clipPath = `inset(0 ${100 - v}% 0 0)`;
      handle.style.left = `${v}%`;
    };
    const moveTo = (clientX: number) => {
      const r = ba.getBoundingClientRect();
      set(((clientX - r.left) / r.width) * 100);
    };
    ba.addEventListener('pointerdown', (e) => {
      drag = true;
      ba.setPointerCapture(e.pointerId);
      moveTo(e.clientX);
    });
    ba.addEventListener('pointermove', (e) => {
      if (drag) moveTo(e.clientX);
    });
    ba.addEventListener('pointerup', () => (drag = false));
    ba.addEventListener('pointercancel', () => (drag = false));
    set(50);
  }

  const escAttr = (s: string) => s.replace(/"/g, '&quot;');
  const sliderHTML = (before: string, after: string, alt: string) => `<div class="ba" data-ba>
      <img class="ba-after" src="${after}" alt="После — ${escAttr(alt)}" draggable="false">
      <img class="ba-before" src="${before}" alt="До — ${escAttr(alt)}" draggable="false">
      <span class="ba-badge is-before">ДО</span><span class="ba-badge is-after">ПОСЛЕ</span>
      <div class="ba-handle"><span class="ba-line"></span><span class="ba-grip">⇆</span></div>
    </div>`;

  // статические слайдеры (карточки, страница кейса)
  document.querySelectorAll('[data-ba]').forEach((el) => {
    if (el instanceof HTMLElement) wireSlider(el);
  });

  // --- лайтбокс ---
  const lb = document.getElementById('lb');
  const stage = document.getElementById('lb-stage');
  const controls = document.getElementById('lb-controls');
  const titleEl = document.getElementById('lb-title');
  const closeBtn = document.getElementById('lb-close');

  if (lb && stage && controls && titleEl && closeBtn) {
    let gImages: Img[] = [];
    let gIndex = 0;

    const showImage = () => {
      const img = stage.querySelector('img');
      const counter = controls.querySelector('.lb-counter');
      const it = gImages[gIndex];
      if (it && img instanceof HTMLImageElement) {
        img.src = it.src;
        img.alt = it.alt || '';
      }
      if (counter) counter.textContent = `${gIndex + 1} / ${gImages.length}`;
    };

    const step = (delta: number) => {
      if (!gImages.length) return;
      gIndex = (gIndex + delta + gImages.length) % gImages.length;
      showImage();
    };

    const open = (data: LbData) => {
      stage.innerHTML = '';
      controls.innerHTML = '';
      titleEl.textContent = data.title || '';

      if (data.mode === 'compare') {
        stage.innerHTML = `<div class="lb-compare mode-wipe">
          <div class="lb-wipe">${sliderHTML(data.before, data.after, data.title || '')}</div>
          <div class="lb-sbs">
            <div><img src="${data.before}" alt="До"><span class="ba-badge is-before">ДО</span></div>
            <div><img src="${data.after}" alt="После"><span class="ba-badge is-after">ПОСЛЕ</span></div>
          </div>
        </div>`;
        controls.innerHTML = `<div class="lb-toggle">
          <button type="button" data-mode="wipe" class="is-active">Слайдер</button>
          <button type="button" data-mode="sbs">Рядом</button>
        </div>`;
        const compare = stage.querySelector('.lb-compare');
        const ba = stage.querySelector('.ba');
        if (ba instanceof HTMLElement) wireSlider(ba);
        controls.querySelectorAll('.lb-toggle button').forEach((b) => {
          if (!(b instanceof HTMLElement)) return;
          b.addEventListener('click', () => {
            controls
              .querySelectorAll('.lb-toggle button')
              .forEach((x) => x.classList.remove('is-active'));
            b.classList.add('is-active');
            const sbs = b.dataset.mode === 'sbs';
            compare?.classList.toggle('mode-sbs', sbs);
            compare?.classList.toggle('mode-wipe', !sbs);
          });
        });
      } else {
        gImages = data.images || [];
        gIndex = Math.min(Math.max(0, data.start || 0), Math.max(0, gImages.length - 1));
        stage.innerHTML = `<div class="lb-gallery">
          <button class="lb-nav prev" type="button" aria-label="Назад">‹</button>
          <img alt="">
          <button class="lb-nav next" type="button" aria-label="Вперёд">›</button>
        </div>`;
        controls.innerHTML = `<div class="lb-counter"></div>`;
        const prev = stage.querySelector('.lb-nav.prev');
        const next = stage.querySelector('.lb-nav.next');
        if (prev instanceof HTMLElement) prev.addEventListener('click', () => step(-1));
        if (next instanceof HTMLElement) next.addEventListener('click', () => step(1));
        if (gImages.length < 2) {
          if (prev instanceof HTMLElement) prev.style.display = 'none';
          if (next instanceof HTMLElement) next.style.display = 'none';
        }
        showImage();
      }

      lb.classList.add('is-open');
      lb.setAttribute('aria-hidden', 'false');
    };

    const close = () => {
      lb.classList.remove('is-open');
      lb.setAttribute('aria-hidden', 'true');
      setTimeout(() => {
        stage.innerHTML = '';
        controls.innerHTML = '';
        titleEl.textContent = '';
      }, 250);
    };

    document.addEventListener('click', (e) => {
      if (!(e.target instanceof Element)) return;
      const trigger = e.target.closest('[data-lb]');
      if (!trigger) return;
      e.preventDefault();
      const raw = trigger.getAttribute('data-lb');
      if (!raw) return;
      try {
        open(JSON.parse(raw));
      } catch (err) {
        console.error('Lightbox payload parse error', err);
      }
    });

    closeBtn.addEventListener('click', close);
    lb.addEventListener('click', (e) => {
      if (e.target === lb) close();
    });
    document.addEventListener('keydown', (e) => {
      if (!lb.classList.contains('is-open')) return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowRight') step(1);
      if (e.key === 'ArrowLeft') step(-1);
    });
  }
</script>
