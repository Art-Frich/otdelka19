---
import site from '@/data/site.json';
import SocialIcon from '@/components/SocialIcon.astro';
import { enabledSocials, SOCIAL_META } from '@/lib/socials';
import SectionHead from '@/components/SectionHead.astro';
import { telHref, phoneDisplay } from '@/lib/contacts';
const hasPrice = !!site.priceUrl;
const socials = enabledSocials();
---

<section id="kontakty" class="py-[72px]">
  <div class="container-x">
    <div
      class="grid grid-cols-1 items-center gap-10 rounded-3xl border border-border glass p-8 md:grid-cols-[1.2fr_1fr] md:p-12"
    >
      <div>
        <SectionHead
          eyebrow="Контакты"
          title="Обсудим ваш ремонт"
          desc={`Позвоните или напишите в мессенджер — отвечу, сориентирую по срокам и при необходимости приеду на замер. Работаю в ${site.areaServed.join(', ')}.`}
        />
        {
          site.masterName && (
            <p class="mt-4 text-[15px]">
              <span class="text-muted">Мастер — </span>
              <span class="font-display font-semibold">{site.masterName}</span>
            </p>
          )
        }
        {
          hasPrice && (
            <a
              href={site.priceUrl}
              target="_blank"
              rel="noopener"
              class="mt-5 inline-flex items-center gap-2 text-[15px] font-semibold text-accent"
            >
              Прайс-лист →
            </a>
          )
        }
      </div>
      <div class="flex flex-col gap-3.5">
        <a href={telHref} class="flex items-center gap-3.5 text-[17px]">
          <span class="grid h-11 w-11 flex-none place-items-center rounded-xl bg-accent-soft text-accent">☎</span>
          <span class="font-display font-semibold">
            {phoneDisplay}
            <span class="block text-[13px] font-normal text-muted">Звонок · {site.workingHours}</span>
          </span>
        </a>
        {
          socials.map((s) => (
            <a
              href={s.url}
              target="_blank"
              rel="noopener"
              class="flex items-center gap-3.5 text-[17px]"
            >
              <span class="grid h-11 w-11 flex-none place-items-center rounded-xl bg-accent-soft text-accent">
                <SocialIcon type={s.type} class="h-5 w-5" />
              </span>
              <span class="font-display font-semibold">
                {SOCIAL_META[s.type].label}
                <span class="block text-[13px] font-normal text-muted">
                  {SOCIAL_META[s.type].hint}
                </span>
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>
