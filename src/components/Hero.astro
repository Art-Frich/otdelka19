---
import site from '@/data/site.json';
import Button from '@/components/Button.astro';
import { telHref } from '@/lib/contacts';
const { hero } = site;
const heroAlt = 'Пример ремонта квартиры под ключ — Абакан';
---

<section class="pt-[64px] pb-16 md:pt-[88px]">
  <div class="container-x grid grid-cols-1 items-center gap-10 md:grid-cols-[1.1fr_0.9fr] md:gap-14">
    <div>
      <div class="text-[13px] font-semibold uppercase tracking-[0.14em] text-accent">
        {hero.eyebrow}
      </div>
      <h1 class="mt-4 text-[clamp(34px,5vw,58px)] font-extrabold">{hero.title}</h1>

      {/* Фото кухни сразу под заголовком — только мобилка */}
      <div
        class="mt-6 aspect-[16/11] overflow-hidden rounded-2xl border border-border shadow-[0_30px_60px_-30px_rgba(0,0,0,0.25)] md:hidden"
      >
        {
          hero.image ? (
            <img src={hero.image} alt={heroAlt} class="h-full w-full object-cover" />
          ) : (
            <div class="h-full w-full bg-[linear-gradient(140deg,#e9dccb,#f6efe6_50%,#d7bda3)]" />
          )
        }
      </div>

      <p class="mt-5 max-w-[30em] text-lg text-muted">{hero.lead}</p>
      <div class="mt-8 flex flex-wrap gap-3.5">
        <Button href={telHref}>Позвонить мастеру</Button>
        <Button href="/portfolio/" variant="secondary">Смотреть работы →</Button>
      </div>
      {
        hero.stats.length > 0 && (
          <div class="mt-10 flex flex-wrap gap-9">
            {hero.stats.map((s) => (
              <div>
                <div class="font-display text-3xl font-extrabold">{s.n}</div>
                <div class="text-[13px] text-muted">{s.l}</div>
              </div>
            ))}
          </div>
        )
      }
    </div>

    {/* Фото — десктоп, правая колонка */}
    <div
      class="hidden aspect-[4/5] overflow-hidden rounded-2xl border border-border shadow-[0_30px_60px_-30px_rgba(0,0,0,0.25)] md:block"
    >
      {
        hero.image ? (
          <img src={hero.image} alt={heroAlt} class="h-full w-full object-cover" />
        ) : (
          <div class="h-full w-full bg-[linear-gradient(140deg,#e9dccb,#f6efe6_50%,#d7bda3)]" />
        )
      }
    </div>
  </div>
</section>
