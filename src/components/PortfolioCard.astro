---
import type { CollectionEntry } from 'astro:content';
import BeforeAfter from '@/components/BeforeAfter.astro';
import { projectView } from '@/lib/projects';

interface Props {
  project: CollectionEntry<'projects'>;
}
const { project } = Astro.props;
const { d, titleLine, metaLine, cover, gallery, href, comparePayload, galleryPayload } =
  projectView(project);

const count = gallery.length;
const photoLabel = count > 1 ? `${count} фото` : 'Открыть';
---

<article
  class="relative overflow-hidden rounded-2xl border border-border bg-surface transition-all duration-200 has-[.card-link:hover]:-translate-y-1 has-[.card-link:hover]:border-accent/40 has-[.card-link:hover]:shadow-[0_28px_50px_-28px_rgba(0,0,0,0.3)]"
>
  {
    d.beforeImage && d.afterImage ? (
      <div class="relative aspect-[4/3] overflow-hidden transition-shadow duration-200 has-[.media-trigger:hover]:ring-[3px] has-[.media-trigger:hover]:ring-accent has-[.media-trigger:hover]:ring-inset">
        <BeforeAfter before={d.beforeImage} after={d.afterImage} alt={d.title} />
        <button
          type="button"
          data-lb={comparePayload}
          aria-label="Открыть «до/после» на весь экран"
          class="media-trigger absolute bottom-3 right-3 z-20 inline-flex cursor-pointer items-center gap-1.5 rounded-full bg-fg/75 px-3 py-1.5 text-xs font-semibold text-bg backdrop-blur transition hover:bg-fg"
        >
          До / После <span class="text-[13px]">⤢</span>
        </button>
      </div>
    ) : (
      <button
        type="button"
        data-lb={galleryPayload()}
        aria-label="Открыть фото на весь экран"
        class="media-trigger group/m relative block aspect-[4/3] w-full cursor-pointer overflow-hidden transition-shadow duration-200 hover:ring-[3px] hover:ring-accent hover:ring-inset"
      >
        {cover ? (
          <img
            src={cover}
            alt={d.title}
            loading="lazy"
            class="h-full w-full object-cover transition duration-500 group-hover/m:scale-105"
          />
        ) : (
          <div class="h-full w-full bg-[linear-gradient(135deg,#e8d6c4,#f6efe6_60%,#dcc4ab)]" />
        )}
        <span class="pointer-events-none absolute left-3 top-3 rounded-md bg-fg/70 px-2 py-1 text-[11px] font-semibold text-bg">
          {d.type}
        </span>
        <span class="pointer-events-none absolute bottom-3 right-3 inline-flex items-center gap-1.5 rounded-full bg-fg/75 px-3 py-1.5 text-xs font-semibold text-bg backdrop-blur">
          {photoLabel} <span class="text-[13px]">⤢</span>
        </span>
      </button>
    )
  }

  <a href={href} class="card-link block px-5 py-5">
    <div class="font-display text-base font-bold">{titleLine}</div>
    {metaLine && <div class="mt-1 text-[13px] text-muted">{metaLine}</div>}
    <div class="mt-3 inline-flex items-center gap-1.5 text-[13px] font-semibold text-accent">
      Смотреть кейс →
    </div>
  </a>
</article>
