---
import type { CollectionEntry } from 'astro:content';
import BeforeAfter from '@/components/BeforeAfter.astro';

interface Props {
  project: CollectionEntry<'projects'>;
}
const { project } = Astro.props;
const d = project.data;

const titleLine = d.area ? `${d.title}, ${d.area} м²` : d.title;
const metaLine = [d.district, d.type, d.duration].filter(Boolean).join(' · ');
const href = `/portfolio/${project.id}/`;

const isCompare = !!(d.beforeImage && d.afterImage);
const cover = d.cover || d.afterImage || d.gallery?.[0]?.src;

// Список фото для галерейного лайтбокса
const galleryImages: { src: string; alt: string }[] = [];
if (cover) galleryImages.push({ src: cover, alt: d.title });
for (const g of d.gallery ?? []) {
  if (g.src !== cover) galleryImages.push({ src: g.src, alt: g.alt || d.title });
}

const payload = isCompare
  ? { mode: 'compare', before: d.beforeImage, after: d.afterImage, title: titleLine }
  : { mode: 'gallery', images: galleryImages, title: titleLine };

const expandLabel = isCompare
  ? 'До / После'
  : galleryImages.length > 1
    ? `${galleryImages.length} фото`
    : 'Открыть';
const hasMedia = isCompare || galleryImages.length > 0;
---

<article
  class="group overflow-hidden rounded-2xl border border-border bg-surface transition hover:-translate-y-1 hover:border-accent/40 hover:shadow-[0_28px_50px_-28px_rgba(0,0,0,0.3)]"
>
  <div class="relative aspect-[4/3] overflow-hidden">
    {
      isCompare ? (
        <BeforeAfter before={d.beforeImage!} after={d.afterImage!} alt={d.title} />
      ) : cover ? (
        <img
          src={cover}
          alt={d.title}
          loading="lazy"
          class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
        />
      ) : (
        <div class="h-full w-full bg-[linear-gradient(135deg,#e8d6c4,#f6efe6_60%,#dcc4ab)]" />
      )
    }

    {
      !isCompare && (
        <span class="pointer-events-none absolute left-3 top-3 z-20 rounded-md bg-fg/70 px-2 py-1 text-[11px] font-semibold text-bg">
          {d.type}
        </span>
      )
    }

    {
      hasMedia && (
        <button
          type="button"
          data-lb={JSON.stringify(payload)}
          aria-label="Открыть на весь экран"
          class="absolute bottom-3 right-3 z-20 inline-flex items-center gap-1.5 rounded-full bg-fg/75 px-3 py-1.5 text-xs font-semibold text-bg backdrop-blur transition hover:bg-fg"
        >
          {expandLabel} <span class="text-[13px]">⤢</span>
        </button>
      )
    }
  </div>

  <a href={href} class="block px-5 py-5">
    <div class="font-display text-base font-bold">{titleLine}</div>
    {metaLine && <div class="mt-1 text-[13px] text-muted">{metaLine}</div>}
    <div class="mt-3 inline-flex items-center gap-1.5 text-[13px] font-semibold text-accent">
      Смотреть кейс →
    </div>
  </a>
</article>
