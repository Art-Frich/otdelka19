---
// Единая кнопка/ссылка с вариантами. Убирает дублирование инлайновых классов.
import { withBase } from '@/lib/url';

interface Props {
  href?: string;
  variant?: 'primary' | 'secondary';
  size?: 'md' | 'sm';
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  [key: string]: unknown;
}
const { href, variant = 'primary', size = 'md', type, class: className, ...rest } = Astro.props;

const base =
  'inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-full font-semibold transition select-none';
const sizes = {
  md: 'h-12 px-6 text-[15px]',
  sm: 'h-11 px-5 text-sm',
};
const variants = {
  primary:
    'bg-accent text-accent-fg shadow-[0_10px_24px_-12px_rgba(184,92,56,0.7)] hover:-translate-y-0.5 hover:brightness-110',
  secondary:
    'bg-surface text-fg border border-border shadow-[0_1px_2px_rgba(0,0,0,0.04)] hover:-translate-y-0.5 hover:border-accent hover:text-accent',
};

const cls = [base, sizes[size], variants[variant], className].filter(Boolean).join(' ');
const Tag = href ? 'a' : 'button';
const attrs = href ? { href: withBase(href) } : { type: type ?? 'button' };
---

<Tag class={cls} {...attrs} {...rest}><slot /></Tag>
