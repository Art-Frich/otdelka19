---
import site from '@/data/site.json';

const nav = [
  { href: '/#uslugi', label: 'Услуги' },
  { href: '/portfolio/', label: 'Работы' },
  { href: '/#kontakty', label: 'Контакты' },
];
---

<header class="sticky top-0 z-30 border-b border-border bg-bg/85 backdrop-blur">
  <div class="mx-auto flex h-[72px] max-w-[1120px] items-center justify-between px-6">
    <a href="/" class="font-display text-xl font-extrabold tracking-tight">
      ОТДЕЛКА<span class="text-accent">19</span>
    </a>
    <nav class="hidden gap-8 text-[15px] text-muted md:flex">
      {nav.map((n) => <a href={n.href} class="transition hover:text-fg">{n.label}</a>)}
    </nav>
    <div class="flex items-center gap-3">
      <a
        href={site.telegram}
        target="_blank"
        rel="noopener"
        class="hidden h-11 items-center rounded-full border border-border px-5 text-sm font-semibold transition hover:border-fg sm:inline-flex"
        >Telegram</a
      >
      <a
        href={`tel:${site.phoneHref}`}
        class="inline-flex h-11 items-center rounded-full bg-accent px-5 text-sm font-semibold text-accent-fg transition hover:brightness-110"
        >Позвонить</a
      >
    </div>
  </div>
</header>
