---
import site from '@/data/site.json';
import SocialLinks from '@/components/SocialLinks.astro';
import Button from '@/components/Button.astro';
import { telHref } from '@/lib/contacts';

const nav = [
  { href: '/#uslugi', label: 'Услуги' },
  { href: '/portfolio/', label: 'Работы' },
  { href: '/#kontakty', label: 'Контакты' },
];
---

<header class="sticky top-0 z-30 border-b border-border bg-bg/85 backdrop-blur">
  <div class="container-x flex h-[72px] items-center justify-between">
    <a href="/" class="leading-none">
      <span class="font-display text-xl font-extrabold tracking-tight"
        >ОТДЕЛКА<span class="text-accent">19</span></span
      >
      {
        site.slogan && (
          <span class="mt-1 block text-[10px] font-medium uppercase tracking-[0.18em] text-muted">
            {site.slogan}
          </span>
        )
      }
    </a>
    <nav class="hidden gap-8 text-[15px] text-muted md:flex">
      {nav.map((n) => <a href={n.href} class="transition hover:text-fg">{n.label}</a>)}
    </nav>
    <div class="flex items-center gap-3">
      <SocialLinks
        class="hidden sm:flex"
        itemClass="h-10 w-10 border border-border hover:border-accent"
        iconClass="h-[18px] w-[18px]"
      />
      <Button href={telHref} size="sm">Позвонить</Button>
    </div>
  </div>
</header>
