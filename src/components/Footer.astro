---
import site from '@/data/site.json';
import SocialLinks from '@/components/SocialLinks.astro';
const year = new Date().getFullYear();
---

<footer class="border-t border-border">
  <div
    class="mx-auto flex max-w-[1120px] flex-wrap items-center justify-between gap-4 px-6 py-9 text-sm text-muted"
  >
    <div>© {year} {site.brand} · {site.areaServed.join(', ')}</div>
    <SocialLinks itemClass="h-9 w-9 hover:text-accent" iconClass="h-[18px] w-[18px]" />
    <div>Ремонт и отделка квартир под ключ</div>
  </div>
</footer>
