---
import site from '@/data/site.json';
---

<div class="fixed bottom-5 right-5 z-40 flex flex-col gap-3">
  <a
    href={site.telegram}
    target="_blank"
    rel="noopener"
    aria-label="Написать в Telegram"
    class="grid h-12 w-12 place-items-center rounded-full bg-surface text-xl text-accent shadow-lg ring-1 ring-border transition hover:-translate-y-0.5"
    >✈</a
  >
  <a
    href={`tel:${site.phoneHref}`}
    aria-label="Позвонить мастеру"
    class="grid h-14 w-14 place-items-center rounded-full bg-accent text-2xl text-accent-fg shadow-lg transition hover:-translate-y-0.5"
    >☎</a
  >
</div>
