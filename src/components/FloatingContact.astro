---
import site from '@/data/site.json';
import SocialIcon from '@/components/SocialIcon.astro';
import { enabledSocials, SOCIAL_META } from '@/lib/socials';
const socials = enabledSocials();
---

<div class="fixed bottom-6 right-0 z-40">
  <div
    id="fab"
    class="fab border border-r-0 border-border bg-surface/95 p-1 shadow-[-12px_12px_40px_rgba(0,0,0,0.18)] backdrop-blur"
  >
    <button
      id="fab-toggle"
      type="button"
      aria-label="Связаться"
      aria-expanded="false"
      class="fab__toggle grid h-12 w-12 shrink-0 place-items-center rounded-l-full text-accent transition hover:bg-accent-soft"
    >
      <svg class="ic-chat h-6 w-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M4 4h16a1 1 0 0 1 1 1v11a1 1 0 0 1-1 1H8l-4 4V5a1 1 0 0 1 1-1z"></path>
      </svg>
      <svg
        class="ic-close h-6 w-6"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="m9 18 6-6-6-6"></path>
      </svg>
    </button>

    <div id="fab-list" class="fab__list pr-2">
      <a
        href={`tel:${site.phoneHref}`}
        aria-label="Позвонить мастеру"
        class="grid h-12 w-12 place-items-center rounded-full text-accent transition hover:bg-accent-soft"
      >
        <svg class="h-[22px] w-[22px]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.5.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.5.1.4 0 .8-.3 1z"
          ></path>
        </svg>
      </a>
      {
        socials.map((s) => (
          <a
            href={s.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={SOCIAL_META[s.type].hint}
            class="grid h-12 w-12 place-items-center rounded-full text-accent transition hover:bg-accent-soft"
          >
            <SocialIcon type={s.type} class="h-[22px] w-[22px]" />
          </a>
        ))
      }
    </div>
  </div>
</div>

<script>
  const fab = document.getElementById('fab');
  const toggle = document.getElementById('fab-toggle');
  if (fab && toggle) {
    const KEY = 'fabOpen';
    const setOpen = (open: boolean) => {
      fab.classList.toggle('is-open', open);
      toggle.setAttribute('aria-expanded', String(open));
      try {
        localStorage.setItem(KEY, open ? '1' : '0');
      } catch {
        // приватный режим — игнорируем
      }
    };
    setOpen(localStorage.getItem(KEY) === '1'); // по умолчанию свёрнуто
    toggle.addEventListener('click', () => setOpen(!fab.classList.contains('is-open')));
  }
</script>
